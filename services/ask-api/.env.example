# Set these in Vercel → Project → Settings → Environment Variables.
# NEVER commit real values. (.env is gitignored.)

# Full Langflow "run flow" URL on Railway (includes the flow id), e.g.
# https://<app>.up.railway.app/api/v1/run/<flow-id>
LANGFLOW_RUN_URL=

# Langflow API key (secret). Server-side only — never in the browser.
LANGFLOW_API_KEY=

# Comma-separated origins allowed to call this function (CORS).
ALLOWED_ORIGINS=https://robertobautistafregoso.github.io,http://localhost:4321

# Rate limits (optional — sensible defaults apply if unset). See api/_rate-limit.mjs.
RATE_IP_PER_MIN=6
RATE_IP_PER_DAY=40
RATE_GLOBAL_PER_DAY=500
