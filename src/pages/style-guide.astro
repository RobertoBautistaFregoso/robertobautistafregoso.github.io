---
import PageLayout from "@/layouts/PageLayout.astro";
---

<PageLayout title="Style Guide" description="Markdown and typography reference." noindex>
  <article class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="mb-6 text-4xl font-medium tracking-tight sm:text-5xl">Style Guide</h1>
    <p class="mb-12 text-lg text-muted-foreground">
      A reference for prose and typography. Full kitchen-sink coming soon (S17).
    </p>
    <div class="prose">
      <h2>Heading 2</h2>
      <p>Standard paragraph with <strong>bold</strong>, <em>italic</em>, and a <a href="#">link</a>.</p>
      <h3>Heading 3</h3>
      <ul>
        <li>List item one</li>
        <li>List item two</li>
      </ul>
      <blockquote>A blockquote for emphasis.</blockquote>
      <pre><code>const hello = "world";</code></pre>
    </div>
  </article>
</PageLayout>
