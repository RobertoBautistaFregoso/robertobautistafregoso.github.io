    <p class="max-w-2xl text-lg leading-relaxed text-muted-foreground">
      Career history and skills.
    </p>
    <p class="mt-8 font-mono text-sm text-muted-foreground/70">
      Full résumé coming soon (S15).
    </p>
  </section>
</PageLayout>
