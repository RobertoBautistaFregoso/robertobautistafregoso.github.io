---
import PageLayout from "@/layouts/PageLayout.astro";
---

<PageLayout
  title="Lab — Roberto Bautista"
  description="Tools, experiments, and interaction showcases."
  noindex
>
  <section class="mx-auto max-w-3xl px-6 pt-12 pb-24 sm:pt-24">
    <h1 class="mb-4 text-4xl font-medium tracking-tight sm:text-5xl">Lab</h1>
    <p class="max-w-xl text-lg text-muted-foreground">
      A gallery of tools, experiments, and interactions.
    </p>
    <p class="mt-8 font-mono text-sm text-muted-foreground/70">
      Experiments coming soon (S16).
    </p>
  </section>
</PageLayout>
