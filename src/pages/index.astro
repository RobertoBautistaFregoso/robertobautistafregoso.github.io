---
import Layout from '../layouts/Layout.astro';

const name = "Roberto Bautista";
const positioning =
  "AI PM — I help enterprises go from AI pilots to shipped, adopted products.";

// JSON-LD Person (ADR-0004: machine/agent readability). Generated from the
// same constants the page renders, so it can't drift from the visible content.
const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name,
  jobTitle: "AI Product Manager",
  description: positioning,
  url: "https://robertobautistafregoso.github.io/",
  sameAs: ["https://github.com/RobertoBautistaFregoso"],
  // TODO: add LinkedIn URL to sameAs when available.
};
---

<Layout title={name} description={positioning}>
  <main>
    <h1>{name}</h1>
    <p class="lead">{positioning}</p>
  </main>
  <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
</Layout>
