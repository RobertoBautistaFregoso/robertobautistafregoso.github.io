---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const name = "Roberto Bautista";
const positioning =
  "AI PM — I help enterprises go from AI pilots to shipped, adopted products.";

const linkedin = "https://www.linkedin.com/in/robertobautistaf/";
const github = "https://github.com/RobertoBautistaFregoso";

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name,
  jobTitle: "AI Product Manager",
  description: positioning,
  url: "https://robertobautistafregoso.github.io/",
  sameAs: [linkedin, github],
};
---

<Layout title={name} description={positioning}>
  <main>
    <h1>{name}</h1>
    <p class="lead">{positioning}</p>

    <section class="projects" aria-labelledby="projects-heading">
      <h2 id="projects-heading">Selected work</h2>
      <ul class="project-list" role="list">
        {
          projects.map((project) => (
            <li class="project-card">
              <h3 class="project-title">{project.data.title}</h3>
              <p class="project-summary">{project.data.summary}</p>
              <p class="project-role">{project.data.role}</p>
              {
                project.data.tags.length > 0 && (
                  <ul class="project-tags">
                    {project.data.tags.map((tag) => (
                      <li class="tag">{tag}</li>
                    ))}
                  </ul>
                )
              }
            </li>
          ))
        }
      </ul>
    </section>

    <section class="contact" aria-labelledby="contact-heading">
      <h2 id="contact-heading">Get in touch</h2>
      <p>The best way to reach me is LinkedIn.</p>
      <a class="cta" href={linkedin} target="_blank" rel="noopener noreferrer">
        Connect on LinkedIn
      </a>
      <p class="contact-secondary">
        Also on <a href={github} target="_blank" rel="noopener noreferrer">GitHub</a>.
      </p>
    </section>
  </main>
  <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
</Layout>
